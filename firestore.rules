rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Pillar 2: Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['name', 'weight', 'height', 'goal', 'onboardingComplete'])
        && data.name is string && data.name.size() <= 100
        && data.weight is number
        && data.height is number
        && data.goal is string && data.goal.size() <= 100
        && data.onboardingComplete is bool
        && (data.get('activityLevel', 'Moderado') is string)
        && (data.get('foodPreferences', []) is list)
        && (data.get('healthGoals', []) is list)
        && (data.get('weightHistory', []) is list)
        && (data.get('dietaryPreferences', []) is list)
        && (data.get('dislikedIngredients', []) is list);
    }

    // --- Users ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      
      allow create: if isOwner(userId) 
        && isValidUser(incoming());
        
      allow update: if isOwner(userId)
        && isValidUser(incoming());

      allow list: if false;
    }
  }
}
